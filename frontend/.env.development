# Used only for `npm run dev` / Vite. Overrides VITE_API_URL from `.env` so the browser
# uses relative `/api` and vite.config.js proxies:
#   /api/events* → event-service (5006)
#   /api*        → gateway or auth (5000)
# This avoids 404 on POST /api/events/upload-cover when port 5000 is not the full gateway.

VITE_API_URL=
