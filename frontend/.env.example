# Copy to .env and fill in values
VITE_API_URL=http://localhost:5000/api

# Optional: mentor Schedule tab → Google Calendar (OAuth). Create an OAuth 2.0 Client ID
# (Web application) in Google Cloud Console, enable Google Calendar API, and add Authorized
# JavaScript origins: e.g. http://localhost:5173
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
