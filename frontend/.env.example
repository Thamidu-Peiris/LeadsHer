# Copy to .env and fill in values
#
# Local Vite dev: leave unset or use `.env.development` (repo includes one) so `/api` is
# proxied — event routes go to event-service :5006; other APIs to :5000. If you set
# VITE_API_URL=http://localhost:5000/api, port 5000 must be the nginx api-gateway that
# proxies to event-service, or event uploads will 404.
VITE_API_URL=http://localhost:5000/api

# Optional: mentor Schedule tab → Google Calendar (OAuth). Create an OAuth 2.0 Client ID
# (Web application) in Google Cloud Console, enable Google Calendar API, and add Authorized
# JavaScript origins: e.g. http://localhost:5173
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
