{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "railpack",
    "buildCommand": "cd backend/services/auth-service && npm install"
  },
  "deploy": {
    "startCommand": "cd backend/services/auth-service && node src/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
