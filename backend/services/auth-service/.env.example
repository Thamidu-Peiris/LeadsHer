# Required (or set in backend/.env / Render)
MONGODB_URI=mongodb://localhost:27017/leadsher
JWT_SECRET=your-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Email (optional – if unset, verification/reset tokens returned in API in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LeadsHer <noreply@example.com>
APP_URL=http://localhost:3000

# Google OAuth (optional – for POST /api/auth/google)
GOOGLE_CLIENT_ID=

# Cloudinary (optional – for profile picture upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
