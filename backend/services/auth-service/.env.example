# Required (or set in backend/.env / Render)
MONGODB_URI=mongodb://localhost:27017/leadsher
JWT_SECRET=your-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Public URL of the frontend — used in password-reset and verify-email links (must match your site)
APP_URL=http://localhost:3000

# Default for new DBs: require email verification on register (admins can change in Dashboard → Settings).
# Set to false to skip verification until the admin toggles it in the UI.
# EMAIL_VERIFICATION_REQUIRED=true

# ── Email (SMTP) — optional in dev; use in production for password-reset / verify-email
# If SMTP_HOST, SMTP_USER, SMTP_PASS are unset, dev may return resetToken in the API instead.
#
# ========== Brevo (https://www.brevo.com) — recommended ==========
# 1) Brevo dashboard → SMTP & API → SMTP: create an SMTP key (this is NOT your account login password).
# 2) Copy "SMTP server", "Login", and the new key. Login is usually your Brevo account email.
# 3) SMTP_FROM must use a sender you verified in Brevo (Campaigns → Senders or domain authentication).
# 4) Port 587 + STARTTLS (default below) matches Brevo’s primary setup. Port 465 needs SMTP_SECURE=true.
#
# Example (fill with your values):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login@email.com
# SMTP_PASS=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMTP_FROM=LeadsHer <verified-sender@yourdomain.com>
#
# Other providers: same variables; set SMTP_PORT / SMTP_SECURE as the provider documents.
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Use quotes on Windows if the address contains spaces: "Name <email@domain.com>"
SMTP_FROM="LeadsHer <noreply@yourdomain.com>"
SMTP_REQUIRE_TLS=
# TLS: only if Node errors with "self-signed certificate in certificate chain" (e.g. antivirus/corporate proxy MITM).
# Removes certificate verification — use only when needed; avoid in production if possible.
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# Google OAuth (optional – for POST /api/auth/google)
GOOGLE_CLIENT_ID=

# Cloudinary (optional – for profile picture upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
